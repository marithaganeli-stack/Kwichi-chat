<!DOCTYPE html>
<html lang="sw">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Video za Kwichi Kwichi</title>
  <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: linear-gradient(135deg, #0a2540, #1e3a8a);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .chat-container {
      width: 100%;
      max-width: 420px;
      height: 92vh;
      background: #0f172a;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0,0,0,0.4);
      display: flex;
      flex-direction: column;
    }
    .header {
      background: #eab308;
      color: #0a2540;
      padding: 18px;
      text-align: center;
      font-size: 21px;
      font-weight: bold;
    }
    .chat-box {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
      background: #0f172a;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .message {
      max-width: 80%;
      padding: 12px 16px;
      border-radius: 18px;
      font-size: 16px;
      line-height: 1.4;
    }
    .sent {
      align-self: flex-end;
      background: #22d3ee;
      color: #0a2540;
      border-bottom-right-radius: 4px;
    }
    .received {
      align-self: flex-start;
      background: #334155;
      color: white;
      border-bottom-left-radius: 4px;
    }
    .input-area {
      background: #ffffff;
      padding: 12px 15px;
      display: flex;
      gap: 10px;
    }
    textarea {
      flex: 1;
      background: #f8fafc;
      color: #1e2937;
      border: 2px solid #e2e8f0;
      border-radius: 25px;
      padding: 14px 20px;
      font-size: 16px;
      resize: none;
      max-height: 120px;
    }
    .send-btn {
      background: #eab308;
      color: #0a2540;
      border: none;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      font-size: 22px;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <div class="chat-container">
    <div class="header">
      Karibu Video za Kwichi Kwichi
    </div>

    <div class="chat-box" id="chatBox">
      <div class="message received">
        Karibu! Andika ujumbe nkutumie video konki tamuuu 😊
      </div>
    </div>

    <div class="input-area">
      <textarea id="messageInput" 
                placeholder="Andika ujumbe wako hapa..." 
                rows="1"></textarea>
      <button class="send-btn" id="sendBtn">➤</button>
    </div>
  </div>

  <script>
    // === FIREBASE CONFIG YAKO (NIMEWEKA TAYARI) ===
    const firebaseConfig = {
      apiKey: "AIzaSyCQEOs_sn8J2EP1SRPXuBhLsK_3NJVmD0-a",
      authDomain: "kwichi-chat.firebaseapp.com",
      projectId: "kwichi-chat",
      storageBucket: "kwichi-chat.firebasestorage.app",
      messagingSenderId: "869405917629",
      appId: "1:869405917629:web:6d9731563c6422dba524d4",
      measurementId: "G-PEHERNDD34"
    };
    // ============================================

    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
    const auth = firebase.auth();

    // Anonymous Login
    auth.signInAnonymously().catch(console.error);

    // Load messages in real time
    function loadMessages() {
      db.collection("messages")
        .orderBy("timestamp")
        .onSnapshot(snapshot => {
          const chatBox = document.getElementById("chatBox");
          chatBox.innerHTML = `
            <div class="message received">
              Karibu! Andika ujumbe nkutumie video konki tamuuu 😊
            </div>
          `;
          
          snapshot.forEach(doc => {
            const data = doc.data();
            const msgDiv = document.createElement("div");
            msgDiv.className = `message ${data.sender === "Video za Kwichi Kwichi" ? "sent" : "received"}`;
            msgDiv.innerHTML = `<strong>${data.sender}:</strong> ${data.text}`;
            chatBox.appendChild(msgDiv);
          });
          chatBox.scrollTop = chatBox.scrollHeight;
        });
    }

    // Send message
    function sendMessage() {
      const input = document.getElementById("messageInput");
      const text = input.value.trim();
      if (!text) return;

      db.collection("messages").add({
        text: text,
        sender: "Video za Kwichi Kwichi",
        timestamp: firebase.firestore.FieldValue.serverTimestamp()
      });

      input.value = "";
    }

    // Event listeners
    document.getElementById("sendBtn").addEventListener("click", sendMessage);
    document.getElementById("messageInput").addEventListener("keypress", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    // Load messages when page opens
    loadMessages();
  </script>
</body>
</html>
